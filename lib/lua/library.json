{
    "name": "lua",
    "version": "5.4.7",
    "description": "Vendored Lua 5.4 interpreter built as a static library for the Pickle OS game runtime.",
    "keywords": ["lua", "scripting", "interpreter"],
    "license": "MIT",
    "frameworks": ["arduino"],
    "platforms": ["espressif32"],
    "build": {
        "srcDir": "src",
        "srcFilter": [
            "+<*.c>",
            "-<lua.c>",
            "-<luac.c>",
            "-<onelua.c>",
            "-<ltests.c>"
        ],
        "includeDir": "src",
        "flags": [
            "-Wno-unused-function",
            "-Wno-implicit-fallthrough",
            "-Wno-deprecated-declarations"
        ]
    }
}
